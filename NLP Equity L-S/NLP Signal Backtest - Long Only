rts_by_day[date] = daily_reports\n","\n","    if not daily_reports.empty:\n","        # Positive if both title and summary are positive + summary positive probability close to 1\n","        is_positive = (\n","            (daily_reports['title_label'] == 'Positive') &\n","            (daily_reports['summary_label'] == 'Positive') &\n","            (daily_reports['summary_score'] >= (1.0 - epsilon))\n","        )\n","        # Negative if summary is negative\n","        is_negative = (daily_reports['summary_label'] == 'Negative')\n","\n","        all_counts = daily_reports.groupby('STOCK_CODE').size()\n","        pos_counts = daily_reports[is_positive].groupby('STOCK_CODE').size()\n","        neg_counts = daily_reports[is_negative].groupby('STOCK_CODE').size()\n","\n","        pos_counts = pos_counts.reindex(all_counts.index, fill_value = 0)\n","        neg_counts = neg_counts.reindex(all_counts.index, fill_value = 0)\n","\n","        pos_fraction = (pos_counts / all_counts).fillna(0)\n","        positive_fraction_by_day[date] = pos_fraction.to_dict()\n","        negative_counts_by_day[date] = neg_counts.astype(int).to_dict()\n","\n","        pos_minus_neg = (pos_counts - neg_counts)\n","        pos_minus_neg_by_day[date] = pos_minus_neg.astype(int).to_dict()\n","\n","        if raw_alpha_type == \"pos-neg\":\n","            raw_alpha = pos_minus_neg\n","        elif raw_alpha_type == \"pos_frac\":\n","            raw_alpha = pos_fraction\n","        else:\n","            raise ValueError(\"raw_alpha_type must be 'pos-neg' or 'pos_frac'\")\n","\n","\n","        final_alpha = raw_to_final(\n","            raw_alpha,\n","            portfolio_mode=portfolio_mode,\n","            weighing=weighing,\n","            remove_zero_raw=remove_zero_raw,\n","            epsilon=epsilon\n","        )\n","\n","        if final_alpha.empty:\n","            final_alpha_by_day[date] = {}\n","            simple_daily_pnl.loc[date]       = 0.0\n","            simple_daily_pnl_long.loc[date]  = 0.0\n","            simple_daily_pnl_short.loc[date] = 0.0\n","            excess_daily_pnl.loc[date]       = 0.0\n","            continue\n","\n","        # print(len(final_alpha))\n","\n","        final_alpha_by_day[date] = final_alpha.sort_index().to_dict()\n","\n","        # Return types\n","        if market_return_type == \"o-c\":         # t+1 Open vs t+1 Close\n","            ret_s = open_to_close.loc[date]\n","            mkt_r = oc_market.loc[date]\n","        elif market_return_type == \"c-c\":       # t+0 Close vs t+1 Close\n","            ret_s = close_to_close.loc[date]\n","            mkt_r = cc_market.loc[date]\n","        elif market_return_type == \"o-o\":       # t+1 Open vs t+2 Open\n","            ret_s = open_to_open.loc[date]\n","            mkt_r = oo_market.loc[date]\n","        else:\n","            raise ValueError(\"market_return_type must be 'o-c', 'c-c', or 'o-o'\")\n","\n","        # Align with returns\n","        ret_s = ret_s.fillna(0)\n","        final_alpha = final_alpha.reindex(ret_s.index).fillna(0)\n","\n","        # Long/short contributions (NO normalization; actual portfolio contributions)\n","        long_contrib  = (final_alpha.clip(lower=0) * ret_s).sum()\n","        short_contrib = (final_alpha.clip(upper=0) * ret_s).sum()  # negative when shorts lose, positive when they make money\n","\n","        # Store leg contributions and total\n","        simple_daily_pnl_long.loc[date]  = long_contrib\n","        simple_daily_pnl_short.loc[date] = -short_contrib\n","\n","        total_pnl = long_contrib + short_contrib\n","        simple_daily_pnl.loc[date] = total_pnl\n","\n","        # Excess PnL: total - market\n","        excess_daily_pnl.loc[date] = total_pnl - mkt_r\n","\n","    else:\n","        positive_fraction_by_day[date] = {}\n","        negative_counts_by_day[date] = {}\n","        pos_minus_neg_by_day[date] = {}\n","        final_alpha_by_day[date] = {}\n","        simple_daily_pnl.loc[date] = 0.0\n","        excess_daily_pnl.loc[date] = 0.0\n","\n","excess_daily_pnl        = excess_daily_pnl.loc[excess_daily_pnl.first_valid_index() : excess_daily_pnl.last_valid_index()]\n","simple_daily_pnl        = simple_daily_pnl.loc[simple_daily_pnl.first_valid_index() : simple_daily_pnl.last_valid_index()]\n","simple_daily_pnl_long   = simple_daily_pnl_long.loc[simple_daily_pnl_long.first_valid_index() : simple_daily_pnl_long.last_valid_index()]\n","simple_daily_pnl_short  = simple_daily_pnl_short.loc[simple_daily_pnl_short.first_valid_index() : simple_daily_pnl_short.last_valid_index()]"]},{"cell_type":"code","source":[],"metadata":{"id":"qtdVqB69QDik"},"execution_count":null,"outputs":[]}],"metadata":{"colab":{"provenance":[],"authorship_tag":"ABX9TyOHPf8nr1Y2zUS0z7a67GEp"},"kernelspec":{"display_name":"Python 3","name":"python3"},"language_info":{"name":"python"}},"nbformat":4,"nbformat_minor":0}