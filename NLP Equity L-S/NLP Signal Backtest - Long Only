{"cells":[{"cell_type":"code","source":["from google.colab import drive\n","import os\n","import pandas as pd\n","from tqdm import tqdm\n","import time\n","import numpy as np\n","import plotly.express as px\n","import plotly.graph_objects as go"],"metadata":{"id":"LwW_-gwpxxNh","executionInfo":{"status":"ok","timestamp":1756160212668,"user_tz":240,"elapsed":3010,"user":{"displayName":"Will Drunkenstein","userId":"13278785159679774259"}}},"execution_count":16,"outputs":[]},{"cell_type":"code","source":["def log_step(step, desc, start, end, t0):\n","    print(f\"[{step}] {desc:<35} {end - start:>6.2f} sec   \"\n","          f\"(total: {end - t0:>6.2f} sec)\")\n","\n","def add_exchange_suffix(code: str) -> str:\n","    code = str(code)\n","\n","    if len(code) == 5 and code.isdigit():\n","        ticker = f\"{code}.HK\"\n","        return ticker\n","\n","    if code.startswith((\"60\", \"68\", \"900\")):\n","        return f\"{code}.SH\"\n","\n","    if code.startswith((\"00\", \"30\", \"200\")):\n","        return f\"{code}.SZ\"\n","\n","    return code"],"metadata":{"id":"_ZKziL7pxz9Z","executionInfo":{"status":"ok","timestamp":1756159952850,"user_tz":240,"elapsed":7,"user":{"displayName":"Will Drunkenstein","userId":"13278785159679774259"}}},"execution_count":2,"outputs":[]},{"cell_type":"code","source":["t0_block1 = time.time()\n","print(\"   Data Ingest Pipeline - Mirroring Files\")\n","print(\"=\"*80)\n","\n","# Mount Google Drive\n","drive.mount('/content/drive', force_remount=True)\n","\n","base_dir  = '/content/drive/MyDrive/Event Log/2025-7-28 申毅实习/策略研究/NLP 日度'\n","index_dir = os.path.join(base_dir, 'Index Price Data')\n","zip_file  = os.path.join(base_dir, 'Stock Price Data.zip')\n","reports_file = os.path.join(base_dir, 'equity_reports.csv')\n","sentiment_file = os.path.join(base_dir, 'sentiment_output.csv')\n","\n","def log_step(step, desc, start, end, t0):\n","    print(f\"[{step}] {desc:<35} {end - start:>6.2f} sec   \"\n","          f\"(total: {end - t0:>6.2f} sec)\")\n","    print(\"-\" * 80)\n","\n","# Copy ZIP, index, reports, sentiment\n","t_copy_start = time.time()\n","!cp \"$zip_file\" /content/\n","!cp -r \"$index_dir\" /content/\n","!cp \"$reports_file\" /content/\n","!cp \"$sentiment_file\" /content/\n","t_copy_end = time.time()\n","log_step(\"Copy\", \"ZIP + Index + Reports + Sentiment\", t_copy_start, t_copy_end, t0_block1)\n","\n","# Unzip stock data\n","t_unzip_start = time.time()\n","!unzip -q \"/content/Stock Price Data.zip\" -d /content/\n","t_unzip_end = time.time()\n","log_step(\"Unzip\", \"Stock Price Data\", t_unzip_start, t_unzip_end, t0_block1)\n","\n","# Confirm local directories\n","local_stock_dir = \"/content/Price Data\"        # fixed: stock csvs\n","local_index_dir = \"/content/Index Price Data\"  # fixed: index csvs\n","local_reports_file = \"/content/equity_reports.csv\"\n","local_sentiment_file = \"/content/sentiment_output.csv\"\n","\n","t1_block1 = time.time()\n","print(\"=\"*80)\n","print(f\"Mirroring finished in {t1_block1 - t0_block1:.2f} sec\")\n","print(\"=\"*80)"],"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"id":"qIyPjgvPQ2Tx","executionInfo":{"status":"ok","timestamp":1756160015345,"user_tz":240,"elapsed":61795,"user":{"displayName":"Will Drunkenstein","userId":"13278785159679774259"}},"outputId":"969e459c-27f2-498b-8dac-2d3f0725f4c9"},"execution_count":3,"outputs":[{"output_type":"stream","name":"stdout","text":["   Data Ingest Pipeline - Mirroring Files\n","================================================================================\n","Mounted at /content/drive\n","[Copy] ZIP + Index + Reports + Sentiment    37.45 sec   (total:  52.18 sec)\n","--------------------------------------------------------------------------------\n","[Unzip] Stock Price Data                      9.53 sec   (total:  61.71 sec)\n","--------------------------------------------------------------------------------\n","==============================================================