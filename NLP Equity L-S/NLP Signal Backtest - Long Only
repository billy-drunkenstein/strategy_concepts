'STOCK_CODE'].apply(add_exchange_suffix)\n","t_reports_end = time.time()\n","log_step(\"Reports\", \"Equity reports file\", t_reports_start, t_reports_end, t0_block2)\n","\n","# Load sentiment output\n","t_sent_start = time.time()\n","sentiment_output = pd.read_csv(local_sentiment_file)\n","sentiment_output = sentiment_output.drop_duplicates(subset=['REPORT_ID'], keep='first')\n","t_sent_end = time.time()\n","log_step(\"Sentiment\", \"Sentiment output file\", t_sent_start, t_sent_end, t0_block2)\n","\n","t1_block2 = time.time()\n","print(\"=\"*80)\n","print(f\"Loading finished in {t1_block2 - t0_block2:.2f} sec\")\n","print(\"=\"*80)"],"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"id":"asUt97dFQ5jA","executionInfo":{"status":"ok","timestamp":1756160080597,"user_tz":240,"elapsed":60765,"user":{"displayName":"Will Drunkenstein","userId":"13278785159679774259"}},"outputId":"ede21ce8-f4d7-466d-c507-592364851e21"},"execution_count":4,"outputs":[{"output_type":"stream","name":"stdout","text":["   Data Ingest Pipeline - Loading Files\n","================================================================================\n","   Found 5172 stock CSV tickers\n"]},{"output_type":"stream","name":"stderr","text":["   Loading stock CSVs: 100%|██████████| 5172/5172 [00:40<00:00, 127.64it/s]\n"]},{"output_type":"stream","name":"stdout","text":["[Stocks] Loaded 5172 tickers                  40.53 sec   (total:  40.53 sec)\n","--------------------------------------------------------------------------------\n","[Index] Market index                          0.01 sec   (total:  40.55 sec)\n","--------------------------------------------------------------------------------\n","[Reports] Equity reports file                  20.07 sec   (total:  60.61 sec)\n","--------------------------------------------------------------------------------\n","[Sentiment] Sentiment output file                 0.15 sec   (total:  60.76 sec)\n","--------------------------------------------------------------------------------\n","================================================================================\n","Loading finished in 60.76 sec\n","================================================================================\n"]}]},{"cell_type":"code","execution_count":6,"metadata":{"executionInfo":{"elapsed":80,"status":"ok","timestamp":1756160109433,"user":{"displayName":"Will Drunkenstein","userId":"13278785159679774259"},"user_tz":240},"id":"3nZG0te0JVdG"},"outputs":[],"source":["sentiment_output = sentiment_output.merge(\n","    equity_reports[['REPORT_ID', 'STOCK_CODE', 'PUBLISH_DATE', 'UPDATE_TIME']],\n","    on = 'REPORT_ID',\n","    how = 'left'\n",")"]},{"cell_type":"markdown","metadata":{"id":"kdPgWMDPENoU"},"source":["# Backtest"]},{"cell_type":"code","source":["def raw_to_final(\n","    raw_alpha: pd.Series,\n","    *,\n","    portfolio_mode: str = \"l\",        # \"l\" or \"l/s\"\n","    weighing: str = \"signal\",         # \"signal\", \"equal\", \"linear\" (NIY)\n","    remove_zero_raw: bool = False,\n","    epsilon: float = 1e-6\n",") -> pd.Series:\n","\n","    if raw_alpha is None or len(raw_alpha) == 0:\n","        return pd.Series(dtype=float)\n","\n","    raw_alpha = raw_alpha.copy()\n","\n","    if remove_zero_raw:\n","        raw_alpha = raw_alpha[raw_alpha != 0]\n","\n","    if raw_alpha.empty:\n","        return pd.Series(dtype=float)\n","\n","    raw_alpha = raw_alpha.astype(float)\n","    raw_alpha -= raw_alpha.mean()\n","\n","    if portfolio_mode == \"l\":                               # Long-only above-average: remove negatives/zeros\n","        raw_alpha = raw_alpha[raw_alpha > 0]\n","        if raw_alpha.empty:\n","            return pd.Series(dtype=float)\n","\n","        if weighing == \"signal\":\n","            w = raw_alpha / raw_alpha.sum()\n","        elif weighing == \"equal\":\n","            w = pd.Series(1.0 / len(raw_alpha), index=raw_alpha.index)\n","        elif weighing == \"linear\":\n","            raise NotImplementedError(\"weighing='linear' is not implemented yet.\")\n","        else:\n","            raise ValueError(\"weighing must be 'signal', 'equal', or 'linear'\")\n","\n","        # Sanity (nonnegative & unit notional)\n","        assert (w >= 0).all(), \"Long-only invariant broken (negative weight)\"\n","        assert abs(w.sum() - 1.0) < epsilon, f\"Long-only weights must sum to 1 (got {w.sum()})\"\n","        return w\n","\n","    elif portfolio_mode == \"l/s\":                           # Long/Short\n","        if weighing == \"signal\":\n","            longs = raw_alpha[raw_alpha > 0]\n","            shorts = raw_alpha[raw_alpha < 0]\n","\n","            w_long = pd.Series(dtype=float)\n","            w_short = pd.Series(dtype=float)\n","\n","            if not longs.empty:\n","                w_long = longs / longs.sum()  # long gross = 1\n","            if not shorts.empty:\n","                w_short = -(shorts.abs() / shorts.abs().sum())  # short gross = 1\n","\n","            w = pd.concat([w_long, w_short])\n","\n","        elif weighing == \"equal\":\n","            longs_idx  = raw_alpha[raw_alpha > 0].index\n","            shorts_idx = raw_alpha[raw_alpha < 0].index\n","\n","            if (len(longs_idx) == 0) and (len(shorts_idx) == 0):\n","                return pd.Series(dtype=float)\n","\n","            if (len(longs_idx) > 0) and (len(shorts_idx) > 0):\n","                w = pd.concat([\n","                    pd.Series(1.0 / len(longs_idx),  index=longs_idx),\n","                    pd.Series(-1.0 / len(shorts_idx), index=shorts_idx)\n","                ]).sort_index()\n","            elif len(longs_idx) > 0:\n","                # Only longs today: gross = 1 on long side\n","                w = pd.Series(1.0 / len(longs_idx), index=longs_idx)\n","            else:\n","                # Only shorts today: gross = 1 on short side\n","                w = pd.Series(-1.0 / len(shorts_idx), index=shorts_idx)\n","\n","        elif weighing == \"linear\":\n","            raise NotImplementedError(\"weighing='linear' is not implemented yet.\")\n","        else:\n","            raise ValueError(\"weighing must be 'signal', 'equal', or 'linear'\")\n","\n","        # Sanity: if both legs exist, gross = 2 and net ~ 0\n","        if (w > 0).any() and (w < 0).any():\n","            assert abs(w[w > 0].sum() - 1.0) < epsilon, f\"Long gross != 1 (got {w[w > 0].sum()})\"\n","            assert abs(w[w < 0].abs().sum() - 1.0) < epsilon, f\"Short gross != 1 (got {w[w < 0].abs().sum()})\"\n","            assert abs(w.sum()) < epsilon, f\"Dollar neutrality violated: net={w.sum()}\"\n","\n","        return w\n","\n","    else:\n","        raise ValueError(\"portfolio_mode must be 'l' or 'l/s'\")"],"metadata":{"id":"S2VwqSeiWYcn","executionInfo":{"status":"ok","timestamp":1756160121667,"user_tz":240,"elapsed":18,"user":{"displayName":"Will Drunkenstein","userId":"13278785159679774259"}}},"execution_count":7,"outputs":[]},{"cell_type":"code","source":["def build_open_to_open_returns(\n","    stocks: dict,\n","    market_df: pd.DataFrame,\n","    trade_period: int,\n","    start_window: pd.Timestamp,\n","    end_window: pd.Timestamp,\n","    look_back: int\n","):\n","    cal = market_df.index\n","\n","    signal_start = start_window + pd.Timedelta(days=look_back)\n","    signal_mask = (cal >= signal_start) & (cal < end_window)\n","    signal_idx = cal[signal_mask]\n","\n","    if len(signal_idx) == 0:\n","        return (\n","            pd.DataFrame(index=signal_idx, dtype=float),\n","            pd.Series(index=signal_idx, dtype=float, name=\"oo_market\"),\n","            signal_idx\n","        )\n","\n","    # 2) Map signal days to entry/exit dates on market calendar\n","    pos = cal.get_indexer(signal_idx)      # integer positions of signal days\n","    entry_pos = pos + 1\n","    exit_pos  = pos + 1 + trade_period\n","\n","    entry_dates = pd.Series(pd.NaT, index=signal_idx)\n","    exit_dates  = pd.Series(pd.NaT, index=signal_idx)\n","\n","    in_bounds_entry = (entry_pos >= 0) & (entry_pos < len(cal))\n","    in_bounds_exit  = (exit_pos  >= 0) & (exit_pos  < len(cal))\n","\n","    if in_bounds_entry.any():\n","        entry_dates.iloc[in_bounds_entry] = cal[entry_pos[in_bounds_entry]]\n","    if in_bounds_exit.any():\n","        exit_dates.iloc[in_bounds_exit]   = cal[exit_pos[in_bounds_exit]]\n","\n","    # 3) Market open→open returns\n","    o_mkt = market_df['openrecovered']\n","    entry_mkt_px = entry_dates.map(o_mkt)\n","    exit_mkt_px  = exit_dates.map(o_mkt)\n","    oo_market = (exit_mkt_px / entry_mkt_px) - 1\n","    oo_market.name = 'oo_market'\n","\n","    # 4) Per-stock open→open returns\n","    cols = {}\n","    for ticker, df in stocks.items():\n","        o = df['openrecovered']\n","        epx = entry_dates.map(o)\n","        xpx = exit_dates.map(o)\n","        cols[ticker] = (xpx / epx) - 1\n","\n","    open_to_open = pd.DataFrame(cols, index=signal_idx)\n","\n","    # 5) Non-overlapping trading_days\n","    trading_days = signal_idx[::trade_period]\n","\n","    return open_to_open, oo_market, trading_days"],"metadata":{"id":"rWSET0w7TkL9","executionInfo":{"status":"ok","timestamp":1756160123682,"user_tz":240,"elapsed":9,"user":{"displayName":"Will Drunkenstein","userId":"13278785159679774259"}}},"execution_count":8,"outputs":[]},{"cell_type":"code","execution_count":9,"metadata":{"executionInfo":{"elapsed":4300,"status":"ok","timestamp":1756160131167,"user":{"displayName":"Will Drunkenstein","userId":"13278785159679774259"},"user_tz":240},"id":"cxqHA84XCI9k"},"outputs":[],"source":["# Parameters\n","look_back = 7\n","epsilon = 1e-6\n","start_window = pd.Timestamp('2022-01-01')\n","end_window   = pd.Timestamp('2023-01-01')\n","market_return_type = \"o-o\"\n","remove_zero_raw = True\n","raw_alpha_type = \"pos_frac\" # [\"pos-neg\", \"pos_frac\"]\n","weighing = \"signal\"\n","portfolio_mode = 'l/s'\n","trade_period = 5\n","\n","# trading_days = market_df.index[(market_df.index >= start_window) & (market_df.index <= end_window)]\n","open_to_open, oo_market, trading_days = build_open_to_open_returns(stocks, market_df, trade_period, start_window, end_window, look_back)"]},{"cell_type":"code","execution_count":10,"metadata":{"executionInfo":{"elapsed":1027,"status":"ok","timestamp":1756160145552,"user":{"displayName":"Will Drunkenstein","userId":"13278785159679774259"},"user_tz":240},"id":"m81R_RNKEqhB"},"outputs":[],"source":["reports_by_day = {}\n","positive_fraction_by_day = {}\n","negative_counts_by_day = {}\n","pos_minus_neg_by_day = {}\n","final_alpha_by_day = {}\n","\n","simple_daily_pnl        = pd.Series(index=trading_days, dtype=float)\n","excess_daily_pnl        = pd.Series(index=trading_days, dtype=float)\n","simple_daily_pnl_long   = pd.Series(index=trading_days, dtype=float)\n","simple_daily_pnl_short  = pd.Series(index=trading_days, dtype=float)\n","\n","for date in trading_days:\n","    next_day = date + pd.Timedelta(days=1)\n","    start_dt = date - pd.Timedelta(days=look_back)\n","\n","    mask = (\n","        (sentiment_output['UPDATE_TIME'] < next_day) &\n","        (sentiment_output['PUBLISH_DATE'] > start_dt)\n","    )\n","\n","    # Look-Ahead Bias\n","    assert (sentiment_output.loc[mask, 'UPDATE_TIME'] < next_day).all()\n","\n","    daily_reports = sentiment_output.loc[mask].copy()\n","    reports_by_day[date] = daily_reports\n","\n","    if not daily_reports.empty:\n","        # Positive if both title and summary are positive + summary positive probability close to 1\n","        is_positive = (\n","            (daily_reports['title_label'] == 'Positive') &\n","            (daily_reports['summary_label'] == 'Positive') &\n","            (daily_reports['summary_score'] >= (1.0 - epsilon))\n","        )\n","        # Negative if summary is negative\n","        is_negative = (daily_reports['summary_label'] == 'Negative')\n","\n","        all_counts = daily_reports.groupby('STOCK_CODE').size()\n","        pos_counts = daily_reports[is_positive].groupby('STOCK_CODE').size()\n","        neg_counts = daily_reports[is_negative].groupby('STOCK_CODE').size()\n","\n","        pos_counts = pos_counts.reindex(all_counts.index, fill_value=0)\n","        neg_counts = neg_counts.reindex(all_counts.index, fill_value=0)\n","\n","        pos_fraction = (pos_counts / all_counts).fillna(0)\n","        positive_fraction_by_day[date] = pos_fraction.to_dict()\n","        negative_counts_by_day[date]   = neg_counts.astype(int).to_dict()\n","\n","        pos_minus_neg = (pos_counts - neg_counts)\n","        pos_minus_neg_by_day[date] = pos_minus_neg.astype(int).to_dict()\n","\n","        if raw_alpha_type == \"pos-neg\":\n","            raw_alpha = pos_minus_neg\n","        elif raw_alpha_type == \"pos_frac\":\n","            raw_alpha = pos_fraction\n","        else:\n","            raise ValueError(\"raw_alpha_type must be 'pos-neg' or 'pos_frac'\")\n","\n","        final_alpha = raw_to_final(\n","            raw_alpha,\n","            portfolio_mode=portfolio_mode,\n","            weighing=weighing,\n","            remove_zero_raw=remove_zero_raw,\n","            epsilon=epsilon\n","        )\n","\n","        if final_alpha.empty:\n","            final_alpha_by_day[date] = {}\n","            simple_daily_pnl.loc[date]       = 0.0\n","            simple_daily_pnl_long.loc[date]  = 0.0\n","            simple_daily_pnl_short.loc[date] = 0.0\n","            excess_daily_pnl.loc[date]       = 0.0\n","            continue\n","\n","        final_alpha_by_day[date] = final_alpha.sort_index().to_dict()\n","\n","        # --- Returns: OPEN->OPEN with your trade_period, aligned to signal day 'date'\n","        # open_to_open, oo_market should be prebuilt (dense) and indexed by signal days\n","        ret_s = open_to_open.loc[date].fillna(0)   # per-stock O->O returns for this signal day\n","        mkt_r = oo_market.loc[date]                # market O->O return (scalar for this signal day)\n","\n","        # Align weights to returns universe\n","        final_alpha = final_alpha.reindex(ret_s.index).fillna(0)\n","\n","        # Long/short contributions (no extra normalization here)\n","        long_contrib  = (final_alpha.clip(lower=0) * ret_s).sum()\n","        short_contrib = (final_alpha.clip(upper=0) * ret_s).sum()  # negative when shorts lose\n","\n","        # Store leg contributions and total\n","        simple_daily_pnl_long.loc[date]  = long_contrib\n","        simple_daily_pnl_short.loc[date] = -short_contrib  # as a \"long-style\" positive contribution\n","        total_pnl = long_contrib + short_contrib\n","        simple_daily_pnl.loc[date] = total_pnl\n","\n","        # Excess PnL: total - market\n","        excess_daily_pnl.loc[date] = total_pnl - mkt_r\n","\n","    else:\n","        positive_fraction_by_day[date] = {}\n","        negative_counts_by_day[date]   = {}\n","        pos_minus_neg_by_day[date]     = {}\n","        final_alpha_by_day[date]       = {}\n","        simple_daily_pnl.loc[date]       = 0.0\n","        simple_daily_pnl_long.loc[date]  = 0.0\n","        simple_daily_pnl_short.loc[date] = 0.0\n","        excess_daily_pnl.loc[date]       = 0.0"]},{"cell_type":"code","source":["first_day = simple_daily_pnl.index.min()\n","idx_pos = market_df.index.searchsorted(first_day)\n","\n","if idx_pos > 0:\n","    baseline_day = market_df.index[idx_pos - 1]\n","else:\n","    baseline_day = first_day\n","\n","zero_at_baseline = pd.Series({baseline_day: 0.0}, dtype=float)\n","\n","simple_daily_pnl  = pd.concat([zero_at_baseline, simple_daily_pnl])\n","excess_daily_pnl  = pd.concat([zero_at_baseline, excess_daily_pnl])\n","simple_daily_pnl_long  = pd.concat([zero_at_baseline, simple_daily_pnl_long])\n","simple_daily_pnl_short = pd.concat([zero_at_baseline, simple_daily_pnl_short])"],"metadata":{"id":"dN9_EEgr8jAF","executionInfo":{"status":"ok","timestamp":1756160151429,"user_tz":240,"elapsed":7,"user":{"displayName":"Will Drunkenstein","userId":"13278785159679774259"}}},"execution_count":11,"outputs":[]},{"cell_type":"code","source":["def performance_metrics(simple_daily_pnl, trading_days=252, rebalance_freq=5):\n","    pnl = pd.Series(simple_daily_pnl)\n","\n","    periods_per_year = trading_days / rebalance_freq\n","\n","    # Annualized return\n","    avg_period_return = pnl.mean()\n","    annualized_return = (1 + avg_period_return) ** periods_per_year - 1\n","\n","    # Annualized volatility\n","    period_vol = pnl.std()\n","    annualized_vol = period_vol * np.sqrt(periods_per_year)\n","\n","    # Sharpe ratio\n","    sharpe = np.nan\n","    if annualized_vol != 0:\n","        sharpe = annualized_return / annualized_vol\n","\n","    return {\n","        \"Annualized Return\": annualized_return,\n","        \"Annualized Vol\": annualized_vol,\n","        \"Sharpe\": sharpe\n","    }\n","\n","# Example\n","metrics = performance_metrics(simple_daily_pnl)\n","for k, v in metrics.items():\n","    print(f\"{k}: {v:.4f}\")"],"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"id":"XJw6UPhPVn2J","executionInfo":{"status":"ok","timestamp":1756160167991,"user_tz":240,"elapsed":10,"user":{"displayName":"Will Drunkenstein","userId":"13278785159679774259"}},"outputId":"e21e2851-e826-41f1-9bca-83ea18ce4425"},"execution_count":14,"outputs":[{"output_type":"stream","name":"stdout","text":["Annualized Return: 0.1878\n","Annualized Vol: 0.1271\n","Sharpe: 1.4774\n"]}]},{"cell_type":"code","execution_count":17,"metadata":{"colab":{"base_uri":"https://localhost:8080/","height":542},"executionInfo":{"elapsed":1768,"status":"ok","timestamp":1756160217998,"user":{"displayName":"Will Drunkenstein","userId":"13278785159679774259"},"user_tz":240},"id":"Dyg6sxR3Jddj","outputId":"8edf5a2a-40e1-4e52-9478-e838a860bcde"},"outputs":[{"output_type":"display_data","data":{"text/html":["<html>\n","<head><meta charset=\"utf-8\" /></head>\n","<body>\n","    <div>            <script src=\"https://cdnjs.cloudflare.com/ajax/l