()\n","        pos_counts = daily_reports[is_positive].groupby('STOCK_CODE').size()\n","        neg_counts = daily_reports[is_negative].groupby('STOCK_CODE').size()\n","\n","        pos_counts = pos_counts.reindex(all_counts.index, fill_value=0)\n","        neg_counts = neg_counts.reindex(all_counts.index, fill_value=0)\n","\n","        pos_fraction = (pos_counts / all_counts).fillna(0)\n","        positive_fraction_by_day[date] = pos_fraction.to_dict()\n","        negative_counts_by_day[date] = neg_counts.astype(int).to_dict()\n","\n","        pos_minus_neg = (pos_counts - neg_counts)\n","        pos_minus_neg_by_day[date] = pos_minus_neg.astype(int).to_dict()\n","\n","        if raw_alpha_type == \"pos-neg\":\n","            raw_alpha = pos_minus_neg\n","        elif raw_alpha_type == \"pos_frac\":\n","            raw_alpha = pos_fraction\n","        else:\n","            raise ValueError(\"raw_alpha_type must be 'pos-neg' or 'pos_frac'\")\n","\n","        if remove_zero_raw:\n","            raw_alpha = raw_alpha[raw_alpha != 0]\n","        if raw_alpha.empty:\n","            final_alpha_by_day[date] = {}\n","            simple_daily_pnl.loc[date] = 0.0\n","            excess_daily_pnl.loc[date] = 0.0\n","            continue\n","\n","        s = raw_alpha.astype(float)\n","        s -= s.mean()\n","        abs_sum = s.abs().sum()\n","        if abs_sum != 0:\n","            s /= abs_sum\n","\n","        # Assert dollar-neutral and unit-notional\n","        assert abs(s.sum()) < 1e-12, f\"Alpha not dollar neutral on {date}\"\n","        assert abs(s.abs().sum() - 1.0) < 1e-12\n","\n","        final_alpha_by_day[date] = s.to_dict()\n","\n","        # Simple vs Excess Return\n","        if market_return_type == \"o-c\":\n","            ret_s = open_to_close.loc[date]\n","            mkt_r = oc_market.loc[date]\n","        elif market_return_type == \"c-c\":\n","            ret_s = close_to_close.loc[date]\n","            mkt_r = cc_market.loc[date]\n","        else: